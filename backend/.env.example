PORT=8080

# Local Postgres via `docker compose up` (see docker-compose.yml at repo root).
# Inside the backend container this is overridden to host "postgres" — this
# value is only used when running `go run main.go` directly on your machine.
DATABASE_URL=postgres://macrolens:macrolens@localhost:5432/macrolens?sslmode=disable

# To point at Supabase instead, use the Supavisor pooler (port 5432, IPv4 compatible):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Must be a real random secret — the backend refuses to start with an empty
# value or the "change-me" placeholder. Generate one with:
#   openssl rand -hex 32
# On Render this is auto-generated (see render.yaml); set it yourself for any
# other host.
JWT_SECRET=change-me

OPENAI_API_KEY=

# Nutrition DB lookup — USDA FoodData Central. Defaults to api_key=DEMO_KEY,
# but that key is shared across every DEMO_KEY user and rate-limits fast
# (a handful of meal logs can exhaust it for the day, returning 429s that
# surface in the app as zero-macro, low-confidence items). Get your own
# free key in ~30s: https://fdc.nal.usda.gov/api-key-signup and set it here.
NUTRITION_API_KEY=
NUTRITION_API_BASE=https://api.nal.usda.gov/fdc/v1
