PORT=8080

# Supabase Postgres — use the Supavisor pooler (port 5432, IPv4 compatible)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

JWT_SECRET=change-me

OPENAI_API_KEY=

# Nutrition DB lookup — default is USDA FoodData Central (free, api_key=DEMO_KEY works for testing)
NUTRITION_API_KEY=
NUTRITION_API_BASE=https://api.nal.usda.gov/fdc/v1
